# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# BDD de test : Symfony en mode test ajoute auto le suffixe _test
# donc la BDD finale s'appellera "lolscout_test" (isolee du dev "lolscout")
# Utilisation de root pour avoir les droits de creation de BDD
DATABASE_URL="mysql://root:rootpass@database:3306/lolscout?serverVersion=8.0&charset=utf8mb4"

# Cle Riot factice pour les tests (l'API est mockee, jamais appelee)
RIOT_API_KEY=RGAPI-fake-test-key

# CORS minimal pour les tests
CORS_ALLOW_ORIGIN='^https?://localhost$'
